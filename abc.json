{
  "builder": {
    "name": "@ali/builder-harmony-common",
    "config": {
      "framework": "next",
      "entry": "app/page.tsx",
      "buildCommand": "npm run build:publish",
      "devCommand": "npm run dev",
      "outputDir": "out"
    }
  },
  "cache": {
    "build": {
      "enable": true,
      "cacheDir": [
        "node_modules/.cache/**",
        ".next/cache/**"
      ]
    }
  },
  "nodeVersion": 22
}
