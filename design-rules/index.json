{
  "schemaVersion": 1,
  "name": "Theme Lab Distributed Design Rules",
  "basePath": "design-rules",
  "routing": {
    "instruction": "Read this index first. Load requiredAlways rules, inventory the selected UI by element type, then load only matched rule files from source.",
