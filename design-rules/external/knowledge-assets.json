  "loadRecipes": [
    {
      "id": "existing-product-ui-normalization",
      "stages": [
        "Read local PRODUCT.md, DESIGN.md, AGENTS.md, and design-rules/index.json.",
        "Load page-type-workflow and classify the route.",
        "Use Impeccable product or brand register only after the local register is known.",
        "Use UIUXPROMAX product/style rows only as candidate inputs to Design System Lab tokens.",
        "Implement through local shadcn primitives and semantic tokens.",
        "Run local completion compliance plus Impeccable-style critique/audit/harden checks when requested."
      ]
    },
    {
      "id": "theme-style-generation",
      "stages": [
        "Search UIUXPROMAX products, styles, colors, typography, and charts for candidate rows.",
        "Map selected rows to seed tokens, map tokens, semantic tokens, and shadcn adapter tokens.",
        "Reject rows whose Do Not Use For conflicts with the page type.",
        "Use Impeccable colorize/typeset/layout language to explain the design direction.",
        "Preview through Design System Lab components before exporting guidance."
      ]
    },
    {
      "id": "quality-review",
      "stages": [
        "Run local visual QA and completion compliance.",
        "Use Impeccable audit for measurable implementation checks.",
        "Use Impeccable critique for design judgment with browser evidence.",
        "Use Impeccable harden for long text, empty, error, loading, dense, responsive, and i18n edge cases.",
        "Report missing external assets instead of guessing."
      ]
    }
  ]
}
